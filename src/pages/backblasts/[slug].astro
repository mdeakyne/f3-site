---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { formatDate, aoName } from '../../lib/data';

export async function getStaticPaths() {
  const all = await getCollection('backblasts');
  return all.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const bb = entry.data;
---

<Base title={`${bb.title} — F3 Lawrence`}>
  <article class="max-w-3xl">
    <a href="/backblasts/" class="font-mono text-xs uppercase text-accent-link hover:underline">← All backblasts</a>

    <header class="mt-4 mb-8 border-b border-rule pb-6">
      <p class="font-mono text-xs uppercase tracking-widest text-accent-red mb-2">
        {formatDate(bb.date)} · {aoName(bb.ao ?? '')}
      </p>
      <h1 class="font-display text-5xl sm:text-6xl leading-[0.95] tracking-tight text-ink">{bb.title}</h1>
      <dl class="mt-6 grid grid-cols-2 sm:grid-cols-4 gap-4 font-mono text-xs">
        <div>
          <dt class="uppercase text-muted">Q</dt>
          <dd class="text-ink font-semibold mt-1">{bb.q || '—'}</dd>
        </div>
        <div>
          <dt class="uppercase text-muted">PAX</dt>
          <dd class="text-ink font-semibold mt-1">{bb.total_pax ?? '—'}</dd>
        </div>
        <div>
          <dt class="uppercase text-muted">FNGs</dt>
          <dd class="text-ink font-semibold mt-1">{bb.fngs ?? 0}</dd>
        </div>
        <div>
          <dt class="uppercase text-muted">AO</dt>
          <dd class="text-ink font-semibold mt-1">{aoName(bb.ao ?? '')}</dd>
        </div>
      </dl>
      {bb.pax.length > 0 && (
        <div class="mt-6">
          <div class="font-mono text-xs uppercase text-muted mb-2">Roster</div>
          <div class="flex flex-wrap gap-2">
            {bb.pax.map((name) => (
              <span class="font-mono text-xs bg-surface border border-rule px-2 py-1">{name}</span>
            ))}
          </div>
        </div>
      )}
    </header>

    <div class="prose prose-neutral max-w-none font-body">
      <Content />
    </div>
  </article>
</Base>
