---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { formatDate, aoName } from '../../lib/data';

const all = await getCollection('backblasts');
const sorted = all
  .map((e) => e.data)
  .sort((a, b) => b.date.localeCompare(a.date));

const years = Array.from(new Set(sorted.map((bb) => bb.date.slice(0, 4)))).sort((a, b) => b.localeCompare(a));
---

<Base title={`Backblasts — F3 Lawrence (${sorted.length})`}>
  <header class="mb-10 border-b border-rule pb-6">
    <p class="font-mono text-xs uppercase tracking-widest text-muted mb-2">Archive</p>
    <h1 class="font-display text-5xl sm:text-6xl leading-none tracking-tight text-ink">BACKBLASTS</h1>
    <p class="mt-3 font-heading text-lg text-muted">
      {sorted.length} workouts recorded across {years.length} years.
    </p>
  </header>

  {years.map((year) => {
    const yearRows = sorted.filter((bb) => bb.date.startsWith(year));
    return (
      <section class="mb-12">
        <h2 class="font-display text-4xl text-accent-red mb-3">{year}</h2>
        <ul class="divide-y divide-rule border-y border-rule">
          {yearRows.map((bb, i) => (
            <li class={`grid grid-cols-[5rem_1fr_auto] sm:grid-cols-[6rem_1fr_6rem_6rem_4rem] items-center gap-3 px-4 py-4 ${i % 2 === 1 ? 'bg-surface-muted' : ''}`}>
              <span class="font-mono text-xs text-muted">{formatDate(bb.date)}</span>
              <a href={`/backblasts/${bb.slug}/`} class="font-heading font-semibold hover:text-accent-red">{bb.title}</a>
              <span class="hidden sm:block font-mono text-xs uppercase text-muted">{aoName(bb.ao ?? '')}</span>
              <span class="hidden sm:block font-mono text-xs text-muted">Q: {bb.q || '—'}</span>
              <span class="font-mono text-xs text-muted text-right">{bb.total_pax ?? '—'} pax</span>
            </li>
          ))}
        </ul>
      </section>
    );
  })}
</Base>
