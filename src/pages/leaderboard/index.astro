---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { site, formatDateShort } from '../../lib/data';

// Load backblasts and rebuild posts-by-PAX for each time window.
const allBB = (await getCollection('backblasts')).map((e) => e.data);
const today = new Date();
const monthStart = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-01`;
const yearStart = `${today.getFullYear()}-01-01`;

interface ScopeRow {
  slug: string;
  f3_name: string;
  posts: number;
  qs: number;
  earliest: string | null;
  latest: string | null;
  latest_q: string | null;
}

function tally(filterFrom: string | null): ScopeRow[] {
  const posts = new Map<string, number>();
  const qs = new Map<string, number>();
  const earliest = new Map<string, string>();
  const latest = new Map<string, string>();
  const latestQ = new Map<string, string>();
  const nameBySlug = new Map<string, string>();
  for (const p of site.leaderboard) nameBySlug.set(p.slug, p.f3_name);

  const slugify = (name: string) =>
    name.toLowerCase().trim().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');

  for (const bb of allBB) {
    if (filterFrom && bb.date < filterFrom) continue;
    const posted = new Set<string>();
    for (const name of bb.pax) {
      const slug = slugify(name);
      nameBySlug.set(slug, name);
      posted.add(slug);
    }
    let qSlug = bb.q_slug ?? '';
    if (!qSlug && bb.q) qSlug = slugify(bb.q);
    if (qSlug) {
      posted.add(qSlug);
      if (bb.q && !nameBySlug.has(qSlug)) nameBySlug.set(qSlug, bb.q);
      qs.set(qSlug, (qs.get(qSlug) ?? 0) + 1);
      const prevQ = latestQ.get(qSlug);
      if (!prevQ || bb.date > prevQ) latestQ.set(qSlug, bb.date);
    }
    for (const slug of posted) {
      posts.set(slug, (posts.get(slug) ?? 0) + 1);
      const e = earliest.get(slug);
      if (!e || bb.date < e) earliest.set(slug, bb.date);
      const l = latest.get(slug);
      if (!l || bb.date > l) latest.set(slug, bb.date);
    }
  }
  return Array.from(posts.entries())
    .map(([slug, count]) => ({
      slug,
      f3_name: nameBySlug.get(slug) ?? slug,
      posts: count,
      qs: qs.get(slug) ?? 0,
      earliest: earliest.get(slug) ?? null,
      latest: latest.get(slug) ?? null,
      latest_q: latestQ.get(slug) ?? null,
    }))
    .sort((a, b) => b.posts - a.posts || b.qs - a.qs);
}

const allTime: ScopeRow[] = site.leaderboard.map((p) => ({
  slug: p.slug,
  f3_name: p.f3_name,
  posts: p.posts,
  qs: p.qs,
  earliest: p.earliest,
  latest: p.latest,
  latest_q: p.latest_q,
}));
const thisYear = tally(yearStart);
const thisMonth = tally(monthStart);

const scopes = [
  { id: 'all', label: 'All time', rows: allTime },
  { id: 'year', label: `${today.getFullYear()}`, rows: thisYear },
  { id: 'month', label: 'This month', rows: thisMonth },
];
---

<Base title="Leaderboard — F3 Lawrence">
  <header class="mb-8 border-b border-rule pb-6">
    <p class="font-mono text-xs uppercase tracking-widest text-muted mb-2">Standings</p>
    <h1 class="font-display text-5xl sm:text-6xl leading-none tracking-tight text-ink">LEADERBOARD</h1>
    <p class="mt-3 font-heading text-lg text-muted">Ranked by posts, then Qs. Excludes the Q from their own pax roster.</p>
  </header>

  <div role="tablist" class="flex gap-2 mb-6 border-b border-rule" data-lb-tabs>
    {scopes.map((s, i) => (
      <button
        role="tab"
        data-scope={s.id}
        aria-selected={i === 0 ? 'true' : 'false'}
        class="font-heading font-semibold uppercase tracking-wide px-4 py-2 border-b-2 border-transparent aria-selected:border-accent-red aria-selected:text-accent-red hover:text-accent-red"
      >
        {s.label}
      </button>
    ))}
  </div>

  {scopes.map((s, i) => (
    <section data-scope-panel={s.id} class={i === 0 ? '' : 'hidden'}>
      {s.rows.length === 0 ? (
        <p class="font-mono text-sm text-muted py-8">No posts in this window yet.</p>
      ) : (
        <table class="w-full border-y border-rule">
          <thead>
            <tr class="font-mono text-xs uppercase text-muted">
              <th class="text-left py-2 px-4 w-12">#</th>
              <th class="text-left py-2 px-4">F3 Name</th>
              <th class="text-right py-2 px-4 w-20">Posts</th>
              <th class="text-right py-2 px-4 w-16">Qs</th>
              <th class="hidden md:table-cell text-right py-2 px-4 w-24">Earliest</th>
              <th class="hidden md:table-cell text-right py-2 px-4 w-24">Latest</th>
              <th class="hidden md:table-cell text-right py-2 px-4 w-24">Latest Q</th>
            </tr>
          </thead>
          <tbody>
            {s.rows.map((p, idx) => (
              <tr class={`border-t border-rule ${idx % 2 === 1 ? 'bg-surface-muted' : ''}`}>
                <td class="py-3 px-4 font-display text-2xl text-accent-red">{idx + 1}</td>
                <td class="py-3 px-4 font-heading font-semibold">
                  <a href={`/pax/${p.slug}/`} class="hover:text-accent-red">{p.f3_name}</a>
                  <div class="md:hidden font-mono text-xs font-normal text-muted mt-1">
                    {p.earliest && <span>First {formatDateShort(p.earliest)}</span>}
                    {p.latest && <span class="ml-3">Last {formatDateShort(p.latest)}</span>}
                    {p.latest_q && <span class="ml-3">Last Q {formatDateShort(p.latest_q)}</span>}
                  </div>
                </td>
                <td class="py-3 px-4 font-mono text-right">{p.posts}</td>
                <td class="py-3 px-4 font-mono text-right">{p.qs}</td>
                <td class="hidden md:table-cell py-3 px-4 font-mono text-xs text-right text-muted">{p.earliest ? formatDateShort(p.earliest) : '—'}</td>
                <td class="hidden md:table-cell py-3 px-4 font-mono text-xs text-right text-muted">{p.latest ? formatDateShort(p.latest) : '—'}</td>
                <td class="hidden md:table-cell py-3 px-4 font-mono text-xs text-right text-muted">{p.latest_q ? formatDateShort(p.latest_q) : '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </section>
  ))}
</Base>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('[data-lb-tabs] button');
  tabs.forEach((btn) => {
    btn.addEventListener('click', () => {
      const scope = btn.dataset.scope;
      tabs.forEach((t) => t.setAttribute('aria-selected', t === btn ? 'true' : 'false'));
      document.querySelectorAll<HTMLElement>('[data-scope-panel]').forEach((p) => {
        p.classList.toggle('hidden', p.dataset.scopePanel !== scope);
      });
    });
  });
</script>
