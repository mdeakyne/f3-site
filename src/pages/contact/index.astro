---
import Base from '../../layouts/Base.astro';
import { site } from '../../lib/data';
---

<Base title="Join F3 Lawrence" description="Request an invite to the F3 Lawrence Slack and come post with us. Free, peer-led workouts for men in Lawrence, KS.">
  <section class="max-w-2xl">
    <header class="mb-8 border-b border-rule pb-6">
      <p class="font-mono text-xs uppercase tracking-widest text-muted mb-2">Join us</p>
      <h1 class="font-display text-5xl sm:text-6xl leading-none tracking-tight text-ink">JOIN F3 LAWRENCE</h1>
      <p class="mt-3 font-heading text-lg text-muted">
        The fastest way in is to just show up. See the
        <a href="/locations/" class="text-accent-link underline">locations</a>.
        Want a heads-up first, or an invite to our Slack? Drop a note below and
        <strong class="text-ink">Big Toe</strong> will reach out and get you connected.
      </p>
    </header>

    <form id="contact-form" method="post" action="/api/contact" class="space-y-5">
      <div>
        <label class="font-mono text-xs uppercase text-muted block mb-1">Your name</label>
        <input type="text" name="name" required maxlength="80" class="w-full border border-rule bg-surface px-3 py-2 font-mono" />
      </div>
      <div>
        <label class="font-mono text-xs uppercase text-muted block mb-1">How should we reach you? <span class="text-muted">(Slack, email, phone — your call)</span></label>
        <input type="text" name="reach" maxlength="200" class="w-full border border-rule bg-surface px-3 py-2 font-mono" />
      </div>
      <div>
        <label class="font-mono text-xs uppercase text-muted block mb-1">Which AO are you eyeing?</label>
        <select name="ao" class="w-full border border-rule bg-surface px-3 py-2 font-mono">
          <option value="">— no preference —</option>
          {site.aos.map((a) => <option value={a.name}>{a.name}</option>)}
        </select>
      </div>
      <div>
        <label class="font-mono text-xs uppercase text-muted block mb-1">Anything else? <span class="text-muted">(optional)</span></label>
        <textarea name="message" rows="3" maxlength="1000" class="w-full border border-rule bg-surface px-3 py-2 font-mono"></textarea>
      </div>

      {/* Spam trap — must stay empty; hidden from people. */}
      <div aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden">
        <label>Company<input type="text" name="company" tabindex="-1" autocomplete="off" /></label>
      </div>
      <input type="hidden" name="loaded_at" />

      <button type="submit" class="bg-accent-red text-surface font-heading font-semibold uppercase tracking-wide px-6 py-3 hover:bg-accent-red-bright">
        Send it
      </button>

      <div id="form-status" aria-live="polite" class="font-mono text-sm"></div>
    </form>

    <p class="mt-8 font-mono text-xs text-muted">
      No spam, no list. This goes straight to our leadership — that's it.
    </p>
  </section>
</Base>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  if (form) {
    (form.elements.namedItem('loaded_at') as HTMLInputElement).value = String(Date.now());
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const status = document.getElementById('form-status')!;
      status.textContent = 'Sending …';
      status.className = 'font-mono text-sm text-muted';
      try {
        const res = await fetch('/api/contact', { method: 'POST', body: new FormData(form) });
        if (!res.ok) throw new Error(await res.text());
        status.textContent = "✓ Got it. Big Toe will be in touch soon — welcome aboard.";
        status.className = 'font-mono text-sm text-accent-open font-semibold';
        form.reset();
      } catch (err) {
        status.textContent = `✗ ${(err as Error).message || 'Submission failed. Try again.'}`;
        status.className = 'font-mono text-sm text-accent-red font-semibold';
      }
    });
  }
</script>
